{
  "name": "backend-topwr-booths",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#services/*": "./app/services/*.js",
    "#utils/*": "./app/utils/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#tests/*": "./tests/*.js",
    "#config/*": "./config/*.js",
    "#commands/*": "./commands/*.js"
  },
  "scripts": {
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prepare": "husky || true",
    "start": "node bin/server.js",
    "test": "node ace test",
    "typecheck": "tsc --noEmit",
    "types:check": "tsc --noEmit"
  },
  "lint-staged": {
    "*": "prettier -w --ignore-unknown"
  },
  "prettier": "@solvro/config/prettier",
  "resolutions": {
    "knex": "3.1.0",
    "strtok3": "8.0.1"
  },
  "overrides": {
    "knex": "3.1.0",
    "strtok3": "8.0.1"
  },
  "dependencies": {
    "@adminjs/adonis": "github:Solvro/adminjs-adonis#b2d02d7",
    "@adonisjs/auth": "^9.6.0",
    "@adonisjs/core": "^6.17.0",
    "@adonisjs/cors": "^2.2.1",
    "@adonisjs/drive": "^3.4.1",
    "@adonisjs/lucid": "^21.6.0",
    "@adonisjs/session": "^7.5.1",
    "@solvro/solvronis-metrics": "^1.0.0",
    "@vinejs/vine": "^3.0.0",
    "adminjs": "^7.8.15",
    "adonis-autoswagger": "^3.63.0",
    "luxon": "^3.5.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.2",
    "@adonisjs/eslint-config": "^2.0.0-beta.6",
    "@adonisjs/prettier-config": "^1.4.0",
    "@adonisjs/tsconfig": "^1.4.0",
    "@commitlint/cli": "^19.6.1",
    "@japa/api-client": "^2.0.4",
    "@japa/assert": "^3.0.0",
    "@japa/plugin-adonisjs": "^3.0.1",
    "@japa/runner": "^3.1.4",
    "@solvro/config": "^2.3.0",
    "@swc/core": "1.10.1",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "hot-hook": "^0.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "sharp": "^0.34.4",
    "ts-node-maintained": "^10.9.4",
    "typescript": "~5.7"
  },
  "pnpm": {
    "overrides": {
      "knex": "3.1.0",
      "strtok3": "8.0.1"
    }
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  }
}
